{
  "manifest_version": 3,
  "name": "Marfeel Recirculation Tagger",
  "version": "2.0.0",
  "description": "Tag recirculation modules visually and autofill the Hub Tag Experience form.",
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage",
    "tabs",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Recirculation Tagger",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["https://hub.marfeel.com/*"],
      "js": [
        "content/selector-engine.js",
        "content/namer.js",
        "content/picker.js"
      ],
      "css": ["content/picker.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://hub.marfeel.com/*"],
      "js": ["hub/autofill.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
